# ─── Application ───────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ─── Database ──────────────────────────────────
DATABASE_URL="postgresql://clinic_user:strongpassword@localhost:5432/clinic_db"

# ─── JWT ───────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-also-change-this
JWT_REFRESH_EXPIRES_IN=30d

# ─── SMS (Sparrow SMS Nepal) ───────────────────
SMS_PROVIDER=sparrow          # sparrow | aakash | dummy
SPARROW_SMS_TOKEN=your-sparrow-sms-token
SPARROW_SMS_FROM=ClinicName   # Sender ID (max 11 chars)

# ─── File Uploads ──────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ─── Clinic ────────────────────────────────────
CLINIC_NAME="My Clinic"
DEFAULT_COUNTRY=NP
DEFAULT_CURRENCY=NPR